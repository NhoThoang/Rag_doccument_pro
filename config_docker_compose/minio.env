# --- BASIC ---
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=12345678
MINIO_VOLUMES=/data
MINIO_SERVER_URL=http://localhost:9000
MINIO_BROWSER=on

# --- PERFORMANCE / NETWORK ---
MINIO_API_READY_DEADLINE=5s
MINIO_API_REQUESTS_MAX=4096
MINIO_HTTP_TRACE=off
MINIO_REGION=local
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001

# --- CACHING / MEMORY ---
MINIO_CACHE_DRIVES=/cache
MINIO_CACHE_EXPIRY=72h
MINIO_CACHE_QUOTA=80
MINIO_CACHE_AFTER=10
MINIO_CACHE_WATERMARK_LOW=70
MINIO_CACHE_WATERMARK_HIGH=85

# --- METRICS / HEALTH ---
MINIO_PROMETHEUS_AUTH_TYPE=public
MINIO_HEAL_PARALLEL_SCANS=2
MINIO_HEAL_MAX_SLEEP=1s

# --- LOGGING / DEBUG ---
MINIO_LOGGER_WEBHOOK_ENABLE=off
MINIO_CONSOLE_ENABLE=on


# sysctl -w net.core.somaxconn=4096
# sysctl -w net.ipv4.tcp_fin_timeout=15
# sysctl -w vm.swappiness=10
