# ========== Application ==========
APP_NAME=Embedding Service
APP_VERSION=1.0.0
DEBUG=False
API_PREFIX=/v1

# ========== Server ==========
HOST=0.0.0.0
PORT=6800
WORKERS=2
THREADS=2

# ========== CORS ==========
ENABLE_CORS=True
CORS_ORIGINS=http://localhost:6800,http://localhost:6800,http://127.0.0.1:6800,http://127.0.0.1:6800
# ========== Security ==========
ENABLE_API_KEY_AUTH=True
API_KEY=appdocs123
TRUSTED_HOSTS=localhost,127.0.0.1

# ========== RAG ==========
TOP_K_RETRIEVAL=5
RAG_MIN_SCORE=0.5

# ========== Model ==========
MODEL_PATH=./model_e5_base_multi_onnx/model_int8.onnx
TOKENIZER_PATH=./model_e5_base_multi_onnx/tokenizer_e5_base
MODEL_DEVICE=cpu
EMBEDDING_DIM=768
MAX_SEQ_LENGTH=512
POOLING_STRATEGY=mean

# ========== ONNX Runtime ==========
ORT_INTRA_OP_THREADS=4
ORT_INTER_OP_THREADS=1
ORT_EXECUTION_MODE=parallel

# ========== Batching ==========
EMBEDDING_BATCH_SIZE=32
MAX_BATCH_SIZE=64

# ========== Chunking ==========
CHUNK_SIZE=384
CHUNK_OVERLAP=64
CHUNKING_BATCH_SIZE=100
LONG_SENTENCE_FILE=./logs/long_sentences.log

# ========== File Upload ==========
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=pdf,docx,txt,json,csv,html
# ========== Logging ==========
LOG_LEVEL=INFO
LOG_FORMAT=json

SHM_SIZE=2g
TOKENIZERS_PARALLELISM=false
